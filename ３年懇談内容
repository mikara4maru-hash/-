<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>見取りノート</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --paper:#ECE4D0;
    --paper-deep:#E4DAC0;
    --grid-line:#CBBB94;
    --ink:#2A2724;
    --ink-soft:#5E594C;
    --ink-faint:#9A937E;
    --aka:#AE3527;
    --aka-deep:#8A2A1F;
    --aka-wash:#F3E1DA;
    --ai-navy:#2E4756;
    --paper-white:#F7F3E9;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:transparent;
    color:var(--ink);
    font-family:"Noto Sans JP",sans-serif;
    font-weight:400;
    -webkit-font-smoothing:antialiased;
  }
  .app{
    max-width:1180px;
    margin:0 auto;
    padding:28px 20px 60px;
  }

  /* ---------- Header ---------- */
  .header{
    display:flex;
    align-items:baseline;
    gap:18px;
    margin-bottom:6px;
    flex-wrap:wrap;
  }
  .header .stamp-mark{
    width:34px;height:34px;
    border:2px solid var(--aka);
    border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    color:var(--aka);
    font-family:"Shippori Mincho",serif;
    font-weight:700;
    font-size:15px;
    flex:none;
    transform:rotate(-6deg);
  }
  h1{
    font-family:"Shippori Mincho",serif;
    font-weight:700;
    font-size:clamp(24px,3.2vw,32px);
    letter-spacing:.06em;
    margin:0;
    color:var(--ink);
  }
  .tagline{
    font-size:12.5px;
    color:var(--ink-soft);
    letter-spacing:.04em;
    margin:2px 0 26px;
    padding-left:52px;
  }

  /* ---------- Layout ---------- */
  .grid{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap:22px;
    align-items:start;
  }
  @media (max-width: 860px){
    .grid{grid-template-columns:1fr;}
  }

  .sheet{
    background:var(--paper);
    border:1px solid var(--grid-line);
    border-radius:2px;
    position:relative;
    box-shadow:0 1px 0 rgba(42,39,36,.04), 0 8px 24px -18px rgba(42,39,36,.35);
  }
  .sheet::before{
    content:"";
    position:absolute; inset:0;
    background-image: repeating-linear-gradient(
        var(--grid-line) 0 1px, transparent 1px 34px
      );
    opacity:.35;
    pointer-events:none;
  }
  .sheet-inner{
    position:relative;
    padding:26px 24px 24px;
  }

  .sheet-label{
    font-family:"Shippori Mincho",serif;
    font-size:13px;
    letter-spacing:.14em;
    color:var(--ink-soft);
    display:flex;
    align-items:center;
    gap:10px;
    margin-bottom:18px;
  }
  .sheet-label::after{
    content:"";
    flex:1;
    height:1px;
    background:var(--grid-line);
  }

  /* ---------- Form fields ---------- */
  .field{
    margin-bottom:18px;
  }
  .field:last-of-type{margin-bottom:4px;}
  .field label{
    display:flex;
    align-items:center;
    gap:8px;
    font-size:13px;
    font-weight:600;
    color:var(--ink);
    margin-bottom:6px;
    letter-spacing:.02em;
  }
  .field label .kigo{
    color:var(--ai-navy);
    font-family:"Shippori Mincho",serif;
    font-size:14px;
  }
  .field textarea{
    width:100%;
    min-height:64px;
    resize:vertical;
    background:var(--paper-white);
    border:1px solid var(--grid-line);
    border-radius:1px;
    padding:10px 12px;
    font-family:"Noto Sans JP",sans-serif;
    font-size:14.5px;
    line-height:1.75;
    color:var(--ink);
    outline:none;
    transition:border-color .15s ease, box-shadow .15s ease;
  }
  .field textarea::placeholder{
    color:var(--ink-faint);
  }
  .field textarea:focus{
    border-color:var(--ai-navy);
    box-shadow:0 0 0 3px rgba(46,71,86,.12);
  }
  .field textarea:focus-visible{
    outline:2px solid var(--ai-navy);
    outline-offset:1px;
  }

  /* ---------- Stamp button ---------- */
  .stamp-btn-row{
    display:flex;
    align-items:center;
    gap:16px;
    margin-top:22px;
  }
  .stamp-btn{
    appearance:none;
    border:2.5px solid var(--aka);
    background:transparent;
    color:var(--aka);
    font-family:"Shippori Mincho",serif;
    font-weight:700;
    font-size:16px;
    letter-spacing:.18em;
    width:104px;
    height:104px;
    border-radius:50%;
    cursor:pointer;
    display:flex;
    align-items:center;
    justify-content:center;
    text-align:center;
    line-height:1.4;
    transform:rotate(-4deg);
    transition:transform .12s ease, background .15s ease, color .15s ease;
    flex:none;
  }
  .stamp-btn:hover:not(:disabled){
    transform:rotate(-4deg) scale(1.04);
  }
  .stamp-btn:active:not(:disabled){
    transform:rotate(-4deg) scale(.92);
    background:var(--aka);
    color:var(--paper-white);
  }
  .stamp-btn:focus-visible{
    outline:2px solid var(--ai-navy);
    outline-offset:4px;
  }
  .stamp-btn:disabled{
    opacity:.45;
    cursor:default;
  }
  .stamp-btn.stamped{
    background:var(--aka);
    color:var(--paper-white);
  }
  .stamp-hint{
    font-size:12px;
    color:var(--ink-soft);
    max-width:220px;
    line-height:1.7;
  }
  .reset-link{
    background:none;border:none;
    font-family:"Noto Sans JP",sans-serif;
    font-size:12px;
    color:var(--ink-faint);
    text-decoration:underline;
    cursor:pointer;
    padding:0;
    margin-top:14px;
  }
  .reset-link:hover{color:var(--ink-soft);}

  /* ---------- Output panel ---------- */
  .output-sheet{
    background:var(--paper-white);
    border:1px solid var(--grid-line);
  }
  .output-sheet::before{
    background-image: repeating-linear-gradient(
        var(--aka-wash) 0 1px, transparent 1px 34px
      );
    opacity:.6;
  }
  .empty-state{
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    text-align:center;
    min-height:340px;
    color:var(--ink-faint);
    gap:14px;
  }
  .empty-state .mark{
    width:56px;height:56px;
    border:1.5px dashed var(--ink-faint);
    border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    font-family:"Shippori Mincho",serif;
    font-size:22px;
  }
  .empty-state p{
    font-size:13px;
    line-height:1.9;
    max-width:280px;
    margin:0;
  }

  .loading-state{
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    min-height:340px;
    gap:16px;
    color:var(--ink-soft);
  }
  .brush{
    width:40px;height:40px;
    border:3px solid var(--aka-wash);
    border-top-color:var(--aka);
    border-radius:50%;
    animation:spin 0.9s linear infinite;
  }
  @media (prefers-reduced-motion: reduce){
    .brush{animation:spin 1.8s linear infinite;}
  }
  @keyframes spin{to{transform:rotate(360deg);}}
  .loading-state span{font-size:13px;letter-spacing:.04em;}

  .error-state{
    min-height:200px;
    display:flex;
    flex-direction:column;
    justify-content:center;
    gap:10px;
    color:var(--aka-deep);
    font-size:13.5px;
    line-height:1.8;
  }
  .error-state strong{font-family:"Shippori Mincho",serif;font-size:15px;}

  .result{
    animation:fadein .4s ease;
  }
  @media (prefers-reduced-motion: reduce){
    .result{animation:none;}
  }
  @keyframes fadein{from{opacity:0; transform:translateY(4px);} to{opacity:1; transform:translateY(0);}}

  .result-block{
    margin-bottom:22px;
    padding-left:16px;
    border-left:3px solid var(--aka);
  }
  .result-block:last-child{margin-bottom:6px;}
  .result-block h3{
    font-family:"Shippori Mincho",serif;
    font-size:14.5px;
    font-weight:700;
    color:var(--aka-deep);
    letter-spacing:.06em;
    margin:0 0 8px;
    display:flex;
    align-items:center;
    gap:8px;
  }
  .result-block h3 .num{
    font-size:11px;
    color:var(--paper-white);
    background:var(--aka);
    border-radius:50%;
    width:18px;height:18px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    flex:none;
  }
  .result-block p{
    font-size:14.5px;
    line-height:1.95;
    color:var(--ink);
    margin:0;
    white-space:pre-wrap;
  }

  .result-actions{
    display:flex;
    gap:10px;
    margin-top:18px;
    flex-wrap:wrap;
  }
  .ghost-btn{
    appearance:none;
    background:transparent;
    border:1px solid var(--ai-navy);
    color:var(--ai-navy);
    font-family:"Noto Sans JP",sans-serif;
    font-size:12.5px;
    font-weight:600;
    letter-spacing:.03em;
    padding:8px 16px;
    border-radius:2px;
    cursor:pointer;
    transition:background .15s ease, color .15s ease;
  }
  .ghost-btn:hover{background:var(--ai-navy); color:var(--paper-white);}
  .ghost-btn:focus-visible{outline:2px solid var(--ai-navy); outline-offset:2px;}
  .ghost-btn.copied{background:var(--ai-navy); color:var(--paper-white);}
</style>
</head>
<body>
<div class="app">

  <div class="header">
    <div class="stamp-mark">見</div>
    <h1>見取りノート</h1>
  </div>
  <p class="tagline">日々の事実を、専門的な言葉に。中3の今と、次の一歩へ。</p>

  <div class="grid">

    <!-- INPUT SHEET -->
    <div class="sheet">
      <div class="sheet-inner">
        <div class="sheet-label">事実の記録</div>

        <div class="field">
          <label><span class="kigo">◆</span>授業での様子</label>
          <textarea id="f-class" placeholder="例）発言は少ないが、ノートには自分の考えを丁寧に書き込んでいる。"></textarea>
        </div>
        <div class="field">
          <label><span class="kigo">◆</span>生活面</label>
          <textarea id="f-life" placeholder="例）当番活動を忘れずに続けている。時間を守ることを大切にしている。"></textarea>
        </div>
        <div class="field">
          <label><span class="kigo">◆</span>友人関係</label>
          <textarea id="f-friend" placeholder="例）特定の友人と落ち着いて関わる。困っている子にそっと声をかける場面があった。"></textarea>
        </div>
        <div class="field">
          <label><span class="kigo">◆</span>道徳・総合での反応</label>
          <textarea id="f-moral" placeholder="例）発言はしないが、振り返りシートには深く考えた跡が見える。"></textarea>
        </div>
        <div class="field">
          <label><span class="kigo">◆</span>魅力</label>
          <textarea id="f-charm" placeholder="例）自分のペースを大切にしながら、周りをよく観察している。"></textarea>
        </div>

        <div class="stamp-btn-row">
          <button class="stamp-btn" id="submitBtn" type="button">読み解く</button>
          <p class="stamp-hint">記入した事実をもとに、教師としての専門的な視点を右側に生成します。</p>
        </div>
        <button class="reset-link" id="resetBtn" type="button">すべての記入をクリア</button>
      </div>
    </div>

    <!-- OUTPUT SHEET -->
    <div class="sheet output-sheet">
      <div class="sheet-inner">
        <div class="sheet-label">教師としての視点</div>
        <div id="outputArea">
          <div class="empty-state">
            <div class="mark">朱</div>
            <p>事実を記入して「読み解く」を押すと、そこから読み取れる力や価値、次の一歩、家庭への支援がここに表示されます。</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
const ids = ['f-class','f-life','f-friend','f-moral','f-charm'];
const labels = {
  'f-class':'授業での様子',
  'f-life':'生活面',
  'f-friend':'友人関係',
  'f-moral':'道徳・総合での反応',
  'f-charm':'魅力'
};
const submitBtn = document.getElementById('submitBtn');
const resetBtn = document.getElementById('resetBtn');
const outputArea = document.getElementById('outputArea');

resetBtn.addEventListener('click', () => {
  ids.forEach(id => document.getElementById(id).value = '');
  submitBtn.classList.remove('stamped');
  outputArea.innerHTML = `
    <div class="empty-state">
      <div class="mark">朱</div>
      <p>事実を記入して「読み解く」を押すと、そこから読み取れる力や価値、次の一歩、家庭への支援がここに表示されます。</p>
    </div>`;
});

submitBtn.addEventListener('click', async () => {
  const facts = {};
  let hasContent = false;
  ids.forEach(id => {
    const v = document.getElementById(id).value.trim();
    facts[id] = v;
    if(v) hasContent = true;
  });

  if(!hasContent){
    outputArea.innerHTML = `
      <div class="error-state">
        <strong>記入がありません</strong>
        <p>左側の項目に、少なくとも1つは事実を記入してください。</p>
      </div>`;
    return;
  }

  submitBtn.disabled = true;
  submitBtn.classList.add('stamped');
  outputArea.innerHTML = `
    <div class="loading-state">
      <div class="brush"></div>
      <span>読み解いています…</span>
    </div>`;

  const factLines = ids
    .filter(id => facts[id])
    .map(id => `【${labels[id]}】${facts[id]}`)
    .join('\n');

  const systemPrompt = `あなたは日本の中学校で長年生徒指導・道徳教育の研究を続けてきたベテラン教師であり、教育相談にも通じた専門家です。
担任教師から共有される「生徒の事実の記録」だけをもとに、次の3点をJSON形式のみで出力してください。前置き、後書き、Markdownの装飾（\`\`\`など）は一切含めないでください。

出力するJSONのキーと内容:
- "meaning": 記入された事実から読み取れる、生徒の力や価値を教育的・専門的に意味づける文章。単なる感想ではなく、教育用語や視点（例：自己調整、内省、他者理解、規範意識、非言語的な学びの姿など）を用いて2〜3文でまとめる。
- "next_step": 中学3年生の発達段階（自我同一性の模索、進路選択への不安、対人関係の再編、抽象的思考の発達など）を踏まえた、具体的で現実的な「次の一歩」の指導方針を2〜3文で述べる。担任として明日から実践できる関わり方を含める。
- "home_support": 家庭でできる小さな支援を1〜2点、箇条書きではなく自然な文章で簡潔に述べる。過度な負担を求めず、家庭でも無理なく続けられる具体的な関わり方にする。

事実が空欄の項目は無視してよい。記入された事実の範囲でのみ判断し、事実にない推測を断定的に書かないこと。温かく、しかし専門性のある文体で書くこと。`;

  try{
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-6",
        max_tokens: 1000,
        system: systemPrompt,
        messages: [
          { role: "user", content: `以下が生徒の事実の記録です。\n\n${factLines}` }
        ]
      })
    });

    const data = await response.json();
    const textBlocks = (data.content || []).filter(b => b.type === "text").map(b => b.text).join("\n");
    const clean = textBlocks.replace(/```json|```/g, "").trim();
    const parsed = JSON.parse(clean);

    outputArea.innerHTML = `
      <div class="result">
        <div class="result-block">
          <h3><span class="num">1</span>読み取れる力・価値</h3>
          <p>${escapeHtml(parsed.meaning || '')}</p>
        </div>
        <div class="result-block">
          <h3><span class="num">2</span>次の一歩</h3>
          <p>${escapeHtml(parsed.next_step || '')}</p>
        </div>
        <div class="result-block">
          <h3><span class="num">3</span>家庭でできる支援</h3>
          <p>${escapeHtml(parsed.home_support || '')}</p>
        </div>
        <div class="result-actions">
          <button class="ghost-btn" id="copyBtn" type="button">全文をコピー</button>
        </div>
      </div>`;

    document.getElementById('copyBtn').addEventListener('click', (e) => {
      const text = `【読み取れる力・価値】\n${parsed.meaning || ''}\n\n【次の一歩】\n${parsed.next_step || ''}\n\n【家庭でできる支援】\n${parsed.home_support || ''}`;
      navigator.clipboard.writeText(text).then(() => {
        e.target.textContent = 'コピーしました';
        e.target.classList.add('copied');
        setTimeout(() => {
          e.target.textContent = '全文をコピー';
          e.target.classList.remove('copied');
        }, 1800);
      });
    });

  } catch(err){
    console.error("API error:", err);
    outputArea.innerHTML = `
      <div class="error-state">
        <strong>読み解きに失敗しました</strong>
        <p>通信エラーが発生しました。少し時間をおいて、もう一度「読み解く」を押してください。</p>
      </div>`;
  } finally {
    submitBtn.disabled = false;
  }
});

function escapeHtml(str){
  const div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}
</script>
</body>
</html>
